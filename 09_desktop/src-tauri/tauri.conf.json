{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "HuXa",
  "version": "0.2.13",
  "identifier": "is.huxa.desktop",
  "build": {
    "frontendDist": "../../08_app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HuXa",
